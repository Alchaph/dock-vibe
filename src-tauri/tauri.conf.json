{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Dock",
  "version": "1.0.0",
  "identifier": "com.dock.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Dock - Docker GUI Manager",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' blob:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://hub.docker.com https://registry.hub.docker.com https://github.com https://api.github.com https://objects.githubusercontent.com https://auth.docker.io https://registry-1.docker.io",
      "dangerousDisableAssetCspModification": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "category": "DeveloperTool",
    "shortDescription": "Docker & Podman GUI Manager",
    "longDescription": "Modern cross-platform desktop application for managing Docker and Podman containers with an intuitive interface.",
    "copyright": "Copyright (c) 2024 Dock",
    "publisher": "Dock"
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/{{owner}}/{{repo}}/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYyNDNENzE1MDA4NkNCRjMKUldUenk0WUFGZGREWWlyOEIzTXA3RlpuckFBblJxa0RNdXkxSVhNdjRWdGpLRUxaZjhxRGYrZXkK"
    }
  }
}
